    {
      "parameters": {
        "jsCode": "const rankResult = $input.first().json;\nconst stats = rankResult.market_stats || {};\nconst priceInfo = stats.price_distribution || {};\nconst avgPrice = parseFloat(priceInfo.avg || 0);\nconst minPrice = parseFloat(priceInfo.min || 0);\n\nconst dropThreshold = avgPrice * 0.60;\nconst hasPriceDrop = minPrice < dropThreshold && minPrice > 0;\n\nreturn [{\n  json: {\n    ...rankResult,\n    price_alert: hasPriceDrop,\n    drop_threshold: dropThreshold,\n    keyword: $('Set Search Parameters').first().json.keyword,\n    alert_message: hasPriceDrop\n      ? `Price drop detected! Min $${minPrice.toFixed(2)} vs avg $${avgPrice.toFixed(2)}`\n      : 'Prices within normal range'\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
