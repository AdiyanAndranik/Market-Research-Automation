    {
      "parameters": {
        "jsCode": "const report = $input.first().json;\nconst content = report.content || {};\nconst stats = content.stats || {};\nconst price = stats.price_distribution || {};\n\nreturn [{\n  json: {\n    report_id: report.report_id,\n    keyword: report.keyword,\n    status: report.status,\n    summary: report.summary,\n    pdf_path: report.pdf_path,\n    products: report.products,\n    avg_price: price.avg || 0,\n    avg_rating: stats.avg_rating || 0,\n    top_product: content.top_products?.[0]?.title || 'N/A',\n    top_category: content.top_products?.[0]?.category || 'N/A',\n    sources: (stats.sources || []).join(', '),\n    generated_at: new Date().toISOString()\n  }\n}];"
      },
