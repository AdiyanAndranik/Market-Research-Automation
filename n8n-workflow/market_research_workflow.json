    {
      "parameters": {
        "jsCode": "const scrapeResult = $input.first().json;\nconst products = scrapeResult.products || [];\n\nif (products.length === 0) {\n  throw new Error('No products to analyze');\n}\n\nreturn [{\n  json: {\n    product_ids: products.map(p => p.id),\n    keyword: scrapeResult.keyword,\n    session_id: scrapeResult.session_id,\n    products_found: scrapeResult.products_found,\n    sources_scraped: scrapeResult.sources_scraped,\n    duration_scrape: scrapeResult.duration_seconds\n  }\n}];"
      },
